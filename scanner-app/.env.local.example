# Copy this file to .env.local and fill in your values.
# Next.js requires the NEXT_PUBLIC_ prefix for variables exposed to the browser.

# Your ngrok (or any backend) base URL — no trailing slash.
# If left empty or unset, the app falls back to the hardcoded URL in lib/api.ts.
NEXT_PUBLIC_API_URL=https://your-url.ngrok-free.app
